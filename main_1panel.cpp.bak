#define PxMATRIX_double_buffer true

#include <Arduino.h>
#include <PxMatrix.h>
#include <WiFi.h>
#include <WebServer.h>
#include <math.h>

// ===== ACCESS POINT =====
const char* AP_SSID = "Qoima-Matrix";
const char* AP_PASS = "12345678";

// ===== PINS =====
#define P_A    19
#define P_B    23
#define P_LAT  22
#define P_OE   16

#define W  32
#define H  16

// ===== DISPLAY =====
hw_timer_t *timer = NULL;
portMUX_TYPE timerMux = portMUX_INITIALIZER_UNLOCKED;
uint8_t display_draw_time = 1;

PxMATRIX display(W, H, P_LAT, P_OE, P_A, P_B);

WebServer server(80);

void IRAM_ATTR display_updater() {
  portENTER_CRITICAL_ISR(&timerMux);
  display.display(display_draw_time);
  portEXIT_CRITICAL_ISR(&timerMux);
}

void display_update_enable(bool is_enable) {
  if (is_enable) {
    timer = timerBegin(0, 80, true);
    timerAttachInterrupt(timer, &display_updater, true);
    timerAlarmWrite(timer, 4000, true);
    timerAlarmEnable(timer);
  } else {
    timerDetachInterrupt(timer);
    timerAlarmDisable(timer);
  }
}

// ===== SCROLLING TEXT STATE =====
String scrollText = "Qoima";
uint16_t textColor;
int scrollSpeed = 30;       // ms per pixel
bool newTextReceived = false;

// Color presets
uint16_t colorGreen, colorRed, colorBlue, colorWhite, colorYellow, colorCyan, colorMagenta;

// ===== WEB PAGE =====
const char HTML_PAGE[] PROGMEM = R"rawliteral(
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Qoima Matrix</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,sans-serif;background:#111;color:#fff;
  display:flex;justify-content:center;align-items:center;min-height:100vh}
.card{background:#1a1a2e;border-radius:16px;padding:24px;width:90%;max-width:400px;
  box-shadow:0 8px 32px rgba(0,255,0,0.15)}
h1{color:#2ecc40;text-align:center;margin-bottom:20px;font-size:24px}
input[type=text]{width:100%;padding:14px;border-radius:10px;border:2px solid #333;
  background:#0d0d1a;color:#fff;font-size:18px;margin-bottom:16px;outline:none}
input[type=text]:focus{border-color:#2ecc40}
.colors{display:flex;gap:8px;margin-bottom:16px;justify-content:center;flex-wrap:wrap}
.cbtn{width:40px;height:40px;border-radius:50%;border:3px solid transparent;cursor:pointer;
  transition:all 0.2s}
.cbtn:hover,.cbtn.active{border-color:#fff;transform:scale(1.15)}
.speed{display:flex;align-items:center;gap:12px;margin-bottom:16px}
.speed label{font-size:14px;color:#888;min-width:70px}
.speed input{flex:1;accent-color:#2ecc40}
button{width:100%;padding:14px;border-radius:10px;border:none;
  background:#2ecc40;color:#000;font-size:18px;font-weight:700;cursor:pointer;
  transition:background 0.2s}
button:hover{background:#27ae60}
button:active{transform:scale(0.98)}
.status{text-align:center;color:#666;margin-top:12px;font-size:13px}
</style>
</head>
<body>
<div class="card">
  <h1>Qoima Matrix</h1>
  <input type="text" id="msg" placeholder="Type message..." autofocus>
  <div class="colors">
    <div class="cbtn active" style="background:#2ecc40" data-c="green" onclick="pickColor(this)"></div>
    <div class="cbtn" style="background:#e74c3c" data-c="red" onclick="pickColor(this)"></div>
    <div class="cbtn" style="background:#3498db" data-c="blue" onclick="pickColor(this)"></div>
    <div class="cbtn" style="background:#fff" data-c="white" onclick="pickColor(this)"></div>
    <div class="cbtn" style="background:#f1c40f" data-c="yellow" onclick="pickColor(this)"></div>
    <div class="cbtn" style="background:#1abc9c" data-c="cyan" onclick="pickColor(this)"></div>
    <div class="cbtn" style="background:#e056a0" data-c="magenta" onclick="pickColor(this)"></div>
  </div>
  <div class="speed">
    <label>Speed</label>
    <input type="range" id="spd" min="10" max="80" value="30">
  </div>
  <button onclick="send()">Send</button>
  <div class="status" id="st"></div>
</div>
<script>
let color='green';
function pickColor(el){
  document.querySelectorAll('.cbtn').forEach(b=>b.classList.remove('active'));
  el.classList.add('active');
  color=el.dataset.c;
}
function send(){
  const msg=document.getElementById('msg').value;
  const spd=document.getElementById('spd').value;
  if(!msg){document.getElementById('st').textContent='Type something!';return}
  fetch('/set?msg='+encodeURIComponent(msg)+'&color='+color+'&speed='+spd)
    .then(r=>r.text()).then(t=>{document.getElementById('st').textContent=t})
    .catch(e=>{document.getElementById('st').textContent='Error'});
}
document.getElementById('msg').addEventListener('keydown',e=>{if(e.key==='Enter')send()});
</script>
</body>
</html>
)rawliteral";

// ===== WEB HANDLERS =====
void handleRoot() {
  server.send(200, "text/html", HTML_PAGE);
}

void handleSet() {
  if (server.hasArg("msg")) {
    scrollText = server.arg("msg");
    newTextReceived = true;
  }

  if (server.hasArg("color")) {
    String c = server.arg("color");
    if      (c == "green")   textColor = colorGreen;
    else if (c == "red")     textColor = colorRed;
    else if (c == "blue")    textColor = colorBlue;
    else if (c == "white")   textColor = colorWhite;
    else if (c == "yellow")  textColor = colorYellow;
    else if (c == "cyan")    textColor = colorCyan;
    else if (c == "magenta") textColor = colorMagenta;
  }

  if (server.hasArg("speed")) {
    scrollSpeed = server.arg("speed").toInt();
    if (scrollSpeed < 10) scrollSpeed = 10;
    if (scrollSpeed > 80) scrollSpeed = 80;
  }

  server.send(200, "text/plain", "OK!");
  Serial.print("New text: ");
  Serial.println(scrollText);
}

// ===== LOGO =====
static bool logoBuf[14][14];

void computeLogo() {
  float cx = 5.5f, cy = 5.5f, R = 5.9f, r = 2.8f;
  for (int y = 0; y < 14; y++)
    for (int x = 0; x < 14; x++) {
      float dx = x - cx, dy = y - cy;
      float dist = sqrtf(dx * dx + dy * dy);
      bool px = false;
      if (dist >= r && dist <= R) {
        px = true;
        if (dx > 0 && dy > 0 && atan2f(dy, dx) > 0.25f && atan2f(dy, dx) < 1.25f) px = false;
      }
      if (x >= 4 && x <= 6 && y >= 4 && y <= 6) px = true;
      if (x >= 8 && y >= 8 && x <= 12 && y <= 12 && fabsf((float)(x-8)-(float)(y-8)) < 1.2f) px = true;
      if (x >= 11 && x <= 12 && y >= 11 && y <= 12) px = true;
      logoBuf[y][x] = px;
    }
}

void drawLogo(int ox, int oy, uint16_t color) {
  for (int y = 0; y < 14; y++)
    for (int x = 0; x < 14; x++)
      if (logoBuf[y][x]) {
        int px = ox + x, py = oy + y;
        if (px >= 0 && px < W && py >= 0 && py < H)
          display.drawPixel(px, py, color);
      }
}

// ===== SETUP =====
void setup() {
  Serial.begin(115200);

  display.begin(4);
  display.setFastUpdate(true);
  display.setScanPattern(ZAGZIG);

  colorGreen   = display.color565(40, 210, 50);
  colorRed     = display.color565(255, 50, 30);
  colorBlue    = display.color565(50, 100, 255);
  colorWhite   = display.color565(255, 255, 255);
  colorYellow  = display.color565(255, 220, 0);
  colorCyan    = display.color565(0, 220, 220);
  colorMagenta = display.color565(230, 50, 180);

  textColor = colorGreen;

  display.clearDisplay();
  computeLogo();

  // Start WiFi AP BEFORE display timer (avoid ISR conflicts during init)
  WiFi.mode(WIFI_AP);
  WiFi.softAP(AP_SSID, AP_PASS);
  delay(500);

  // NOW enable display refresh
  display_update_enable(true);

  // Show logo
  display.clearDisplay();
  drawLogo((W - 14) / 2, 1, colorGreen);
  display.showBuffer();
  Serial.print("AP started: ");
  Serial.println(AP_SSID);
  Serial.print("IP: ");
  Serial.println(WiFi.softAPIP());

  delay(1000);

  // Show AP info on display
  display.clearDisplay();
  display.setTextWrap(false);
  display.setTextSize(1);
  display.setTextColor(colorGreen);
  display.setCursor(0, 0);
  display.print("WiFi:");
  display.setTextColor(colorYellow);
  display.setCursor(0, 9);
  display.print("192.168.4.1");
  display.showBuffer();
  delay(3000);

  // Start web server
  server.on("/", handleRoot);
  server.on("/set", handleSet);
  server.begin();
  Serial.println("Web server started at 192.168.4.1");
}

// ===== LOOP =====
void loop() {
  server.handleClient();

  // Scroll the text continuously
  int textWidth = scrollText.length() * 6; // 6px per char at size 1

  display.setTextWrap(false);
  display.setTextSize(1);
  display.setTextColor(textColor);

  for (int x = W; x > -textWidth; x--) {
    // Check for new web requests each frame
    server.handleClient();

    // If new text arrived, restart scroll
    if (newTextReceived) {
      newTextReceived = false;
      break;
    }

    display.clearDisplay();
    display.setCursor(x, 4);
    display.print(scrollText);
    display.showBuffer();
    delay(scrollSpeed);
    yield();
  }
}
